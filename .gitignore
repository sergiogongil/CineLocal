# ============================================================
# CineLocal — .gitignore
# ============================================================
# Los archivos de tu colección personal (películas y carátulas)
# NO deben subirse al repositorio. Este .gitignore los excluye.
# ============================================================

# --- Tu colección de películas (vídeos e imágenes) ---
peliculas/**/*.mp4
peliculas/**/*.mkv
peliculas/**/*.avi
peliculas/**/*.mov
peliculas/**/*.webm
peliculas/**/*.jpg
peliculas/**/*.jpeg
peliculas/**/*.png
peliculas/**/*.webp

# Permitir el directorio vacío y los README de ejemplo
!peliculas/.gitkeep
!peliculas/**/README.md

# --- Sistema operativo ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editores ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# --- Logs y temporales ---
*.log
*.tmp
*.bak
*.swp
*~

# --- Node (por si en el futuro se usa npm) ---
node_modules/
npm-debug.log*
